# Django
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=example.com
DJANGO_ADMIN_URL=admin/
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECURE_SSL_REDIRECT=True

# Database (PostgreSQL  –  provided by Appliku)
DATABASE_URL=postgres://user:password@localhost:5432/agenticbrainrot

# Redis (provided by Appliku  –  used for Huey task queue and caching)
REDIS_URL=redis://localhost:6379/0

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DJANGO_DEFAULT_FROM_EMAIL=AgenticBrainrot <noreply@example.com>
DJANGO_SERVER_EMAIL=AgenticBrainrot <noreply@example.com>
DJANGO_EMAIL_SUBJECT_PREFIX=[AgenticBrainrot]

# Rollbar (production error tracking)
ROLLBAR_ACCESS_TOKEN=your-rollbar-token
ROLLBAR_ENVIRONMENT=production

# Study settings
EXPORT_SECRET_KEY=change-me-to-a-random-secret

# reCAPTCHA
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
